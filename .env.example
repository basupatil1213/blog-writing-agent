# ─────────────────────────────────────────────────────────────────────────────
# Blog Writing Agent — Environment Variables
# Copy this file to .env in the REPO ROOT and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL_NAME=gpt-4o

# ── Tavily (web research) ─────────────────────────────────────────────────────
# Get a free key at https://tavily.com
TAVILY_API_KEY=tvly-...

# ── Google Gemini (image generation) ─────────────────────────────────────────
# Optional — only needed if you want AI-generated diagrams in your blog posts.
# Get a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# ── Server ────────────────────────────────────────────────────────────────────
DEBUG=false
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Storage ───────────────────────────────────────────────────────────────────
# Absolute path where generated images are stored.
# Defaults to <repo>/backend/images/ if not set.
# IMAGES_DIR=/absolute/path/to/images
